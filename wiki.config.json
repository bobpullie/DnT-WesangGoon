{
  "version": "1.1",
  "project_id": "wesang",
  "mode": "session-extract",
  "paths": {
    "wiki_root": "docs/wiki",
    "raw_root": "raw",
    "session_archive_root": "docs/session_archive",
    "sessions_jsonl": "~/.claude/projects/e--DnT-DnT-WesangGoon/*.jsonl"
  },
  "sections": [
    {
      "name": "decisions",
      "template": "decision",
      "phase_tag": null
    },
    {
      "name": "patterns",
      "template": "entity",
      "phase_tag": null
    },
    {
      "name": "concepts",
      "template": "concept",
      "phase_tag": null
    },
    {
      "name": "postmortems",
      "template": "postmortem",
      "phase_tag": "P5"
    },
    {
      "name": "principles",
      "template": "principle",
      "phase_tag": "P10"
    }
  ],
  "auditors": [],
  "frontmatter": {
    "_schema_contract": "Dataview + Calendar plugin 호환 통일 스키마 (S35). date 는 인용 없는 ISO YYYY-MM-DD, tags 는 복수형.",
    "required_fields": [
      "date",
      "status"
    ],
    "optional_fields": [
      "aliases",
      "phase",
      "scope",
      "project",
      "tags",
      "cssclass"
    ],
    "status_values": [
      "Draft",
      "Active",
      "Accepted",
      "Implemented",
      "Observation",
      "Tentative",
      "Confirmed",
      "Superseded",
      "Archived"
    ],
    "date_format": "YYYY-MM-DD",
    "date_quoted": false,
    "tags_key": "tags",
    "tags_style": "flow"
  },
  "lint_cadence": {
    "every_sessions": 5,
    "every_pages": 10
  },
  "obsidian": {
    "vault_path": ".",
    "dataview_enabled": true,
    "graph_exclude_patterns": [
      "docs/session_archive"
    ],
    "daily_notes": {
      "enabled": true,
      "folder": "docs/daily",
      "format": "YYYY-MM-DD",
      "template_path": "docs/templates/daily-note.md",
      "_calendar_plugin_note": "Calendar plugin(liamcain) 은 Daily Notes 코어 플러그인의 format 을 그대로 사용. frontmatter date 포맷과 반드시 동일한 YYYY-MM-DD 유지.",
      "_integration_pattern": "각 wiki 페이지 frontmatter date 와 daily-note 파일명이 일치하면 Daily Note 내 Dataview 쿼리(`WHERE date = this.file.day`) 가 자동 수집."
    },
    "cssclasses": {
      "decision": "twk-decision",
      "concept": "twk-concept",
      "principle": "twk-principle",
      "postmortem": "twk-postmortem",
      "idea": "twk-idea",
      "entity": "twk-entity",
      "daily": "twk-daily",
      "raw": "twk-raw",
      "handover": "twk-handover",
      "recap": "twk-recap",
      "timeline": "twk-timeline"
    }
  },
  "naming_conventions": {
    "session_based": "YYYYMMDD_<name>.md",
    "entity": "<name>.md",
    "decision_adr": "YYYY-MM-DD_<kebab-topic>.md",
    "versioned": "YYYYMMDD_<name>_v<n>.md",
    "daily_note": "YYYY-MM-DD.md"
  }
}
